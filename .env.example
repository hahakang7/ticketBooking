# 로컬 개발 환경 설정 파일
# 이 파일을 복사하여 .env.local을 만들고 필요한 값을 입력하세요
# .env.local은 .gitignore에 포함되어 commit되지 않습니다

# ==========================================
# PostgreSQL Database
# ==========================================
POSTGRES_USER=user
POSTGRES_PASSWORD=password
POSTGRES_DB=booking_system

# ==========================================
# Redis
# ==========================================
REDIS_URL=redis://redis:6379

# ==========================================
# Core API (FastAPI)
# ==========================================
DATABASE_URL=postgresql://user:password@postgres:5432/booking_system
DEBUG=true
LOG_LEVEL=debug
SECRET_KEY=your-secret-key-for-local-development-change-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRATION_HOURS=24
CORS_ORIGINS=["http://localhost:3001","http://localhost:5173"]

# ==========================================
# WebSocket Service (Node.js)
# ==========================================
PORT=3000
NODE_ENV=development
CORE_API_URL=http://core-api:8000
WEBSOCKET_ORIGIN=http://localhost:3001
SOCKET_IO_HEARTBEAT=25000
SOCKET_IO_TIMEOUT=60000

# ==========================================
# Frontend (React + Vite)
# ==========================================
VITE_API_URL=http://localhost:8000
VITE_WS_URL=ws://localhost:3000
VITE_ENV=development

# ==========================================
# Prometheus (모니터링)
# ==========================================
PROMETHEUS_RETENTION=24h
